<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - <%= role === 'shopkeeper' ? 'Shopkeeper' : 'Customer' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.2); }
    </style>
</head>
<body class="bg-slate-900 min-h-screen text-white relative m-0 p-0 overflow-x-hidden">
    <!-- Fixed Background Gradients -->
    <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-blue-600 rounded-full mix-blend-multiply filter blur-[150px] opacity-20"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-purple-600 rounded-full mix-blend-multiply filter blur-[150px] opacity-20"></div>
    </div>

    <!-- Main Scrollable Container -->
    <div class="relative z-10 min-h-screen flex flex-col items-center justify-start md:justify-center py-12 px-6">

    <div class="glass w-full max-w-lg rounded-3xl p-8 relative z-10 shadow-2xl">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold mb-2">Create Account</h1>
            <p class="text-slate-300">Join as a <%= role.charAt(0).toUpperCase() + role.slice(1) %></p>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/20 border border-red-500 text-red-100 p-3 rounded-xl mb-6 text-center">
                <%= error %>
            </div>
        <% } %>

        <form action="/register" method="POST" id="registerForm" class="space-y-4">
            <input type="hidden" name="role" value="<%= role %>">
            <input type="hidden" name="latitude" id="latitude">
            <input type="hidden" name="longitude" id="longitude">

            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Full Name</label>
                <input type="text" name="name" required class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
            </div>

            <% if (role === 'shopkeeper') { %>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Shop Name</label>
                    <input type="text" name="shopName" required class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Service Category</label>
                    <select name="category" required class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        <option value="grocery">Grocery & Essentials</option>
                        <option value="plumber">Plumber & Repairs</option>
                        <option value="electrician">Electrician</option>
                        <option value="salon">Salon & Beauty</option>
                        <option value="pharmacy">Pharmacy</option>
                        <option value="other">Other Services</option>
                    </select>
                </div>
            <% } %>

            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Email Address</label>
                <input type="email" name="email" required class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Phone Number</label>
                <input type="tel" name="phone" required class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-300 mb-1">Password</label>
                <input type="password" name="password" required class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
            </div>

            <div class="pt-2">
                <button type="button" id="getLocationBtn" class="w-full bg-slate-700 hover:bg-slate-600 text-white font-medium py-3 px-4 rounded-xl flex items-center justify-center gap-2 transition-colors mb-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Fetch My Current Location
                </button>
                <p id="locationStatus" class="text-xs text-center text-slate-400 mb-4 h-4"></p>
                
                <button type="submit" id="submitBtn" class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold py-3 px-4 rounded-xl shadow-lg transform hover:-translate-y-0.5 transition-all">
                    Register Account
                </button>
            </div>
            
            <p class="text-center text-sm text-slate-400 mt-4">
                Already have an account? <a href="/login?role=<%= role %>" class="text-blue-400 hover:text-blue-300">Sign in</a>
            </p>
        </form>
    </div>

    <script>
        const getLocationBtn = document.getElementById('getLocationBtn');
        const locationStatus = document.getElementById('locationStatus');
        const latInput = document.getElementById('latitude');
        const lngInput = document.getElementById('longitude');

        getLocationBtn.addEventListener('click', () => {
            if (navigator.geolocation) {
                locationStatus.textContent = 'Locating...';
                getLocationBtn.classList.add('opacity-70', 'cursor-not-allowed');
                
                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        latInput.value = position.coords.latitude;
                        lngInput.value = position.coords.longitude;
                        locationStatus.textContent = 'Location captured successfully! ✅';
                        locationStatus.classList.replace('text-slate-400', 'text-green-400');
                        getLocationBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                        getLocationBtn.classList.replace('bg-slate-700', 'bg-green-700');
                        getLocationBtn.innerHTML = 'Location Set ✓';
                    },
                    (error) => {
                        locationStatus.textContent = "Error: " + error.message + " - Please allow location access.";
                        locationStatus.classList.replace('text-slate-400', 'text-red-400');
                        getLocationBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                    },
                    { enableHighAccuracy: true }
                );
            } else {
                locationStatus.textContent = 'Geolocation is not supported by your browser.';
            }
        });

        // Basic validation: encourage obtaining location before submitting
        document.getElementById('registerForm').addEventListener('submit', (e) => {
            if (!latInput.value || !lngInput.value) {
                const proceed = confirm("Proceed without fetching location? Our service works best when we know your area.");
                if (!proceed) e.preventDefault();
            }
        });
    </script>
    </div>
</body>
</html>
