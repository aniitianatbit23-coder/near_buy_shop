<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Successful - NearBuy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
    <!-- Confetti explosion script for beautiful UI effect -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 flex items-center justify-center p-6">
    
    <div class="bg-white rounded-3xl shadow-2xl border border-slate-100 p-8 md:p-12 max-w-lg w-full text-center relative overflow-hidden">
        <!-- SVG check inside a bubble -->
        <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6 relative">
            <div class="absolute inset-0 bg-green-400 rounded-full animate-ping opacity-20"></div>
            <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>

        <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Order Confirmed!</h1>
        <p class="text-slate-500 mb-6">Your order <span class="font-mono text-slate-700 bg-slate-100 px-2 py-0.5 rounded">#<%= orderId.toString().substring(18) %></span> has been sent to the shopkeeper securely.</p>
        
        <div class="bg-slate-50 rounded-2xl p-6 mb-8 mt-2 border border-slate-100 text-left">
            <div class="flex justify-between items-center mb-3">
                <span class="text-slate-500 text-sm font-medium">Payment Method</span>
                <span class="font-bold uppercase text-xs tracking-wider bg-white rounded-full px-2 py-1 shadow-sm"><%= paymentMethod === 'cod' ? 'Cash on Delivery' : 'Online Payment' %></span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-slate-500 text-sm font-medium">Total Amount</span>
                <span class="font-bold text-indigo-700 text-xl">₹<%= total %></span>
            </div>
            <% if (paymentMethod === 'online') { %>
                <div class="mt-4 pt-4 border-t border-slate-200">
                    <p class="text-xs text-green-600 flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Mock Payment Processed Successfully
                    </p>
                </div>
            <% } %>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
            <a href="/customer/dashboard" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-800 font-semibold py-3 px-4 rounded-xl transition-colors">
                Back to Home
            </a>
            <a href="https://wa.me/<%= shopPhone.replace(/[^0-9]/g, '') %>?text=Hi!%20I%20just%20placed%20order%20%23<%= orderId.toString().substring(18) %>%20for%20%E2%82%B9<%= total %>." target="_blank" class="flex-1 bg-[#25D366] hover:bg-[#128C7E] text-white font-semibold py-3 px-4 rounded-xl transition-colors shadow-md flex items-center justify-center shadow-green-200">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp Shop
            </a>
        </div>
    </div>

    <!-- Trigger Confetti immediately on page load -->
    <script>
        window.onload = function() {
            var duration = 3000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 5,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#2563eb', '#1d4ed8', '#fbbf24']
                });
                confetti({
                    particleCount: 5,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#ec4899', '#db2777', '#fbbf24']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        };
    </script>
</body>
</html>
