<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Dashboard - NearBuy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">
    
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <span class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">NearBuy</span>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-sm font-medium text-slate-500 hidden md:block">Welcome, <%= user.name %>!</span>
                    <a href="/logout" class="text-sm font-medium text-red-600 hover:text-red-500 bg-red-50 hover:bg-red-100 px-4 py-2 rounded-full transition-colors">Sign Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Header Section -->
    <div class="bg-indigo-700 text-white py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-extrabold tracking-tight mb-4">Discover Shops Near You</h1>
            <% if (queryMode === 'nearby') { %>
                <p class="text-indigo-200 text-lg flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                    Showing shops around your saved location
                </p>
            <% } else { %>
                <p class="text-amber-300 text-lg">We couldn't use your location. Showing random nearby shops.</p>
            <% } %>
        </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        
        <!-- My Orders Section -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold mb-6 text-slate-800 flex items-center">
                <svg class="w-6 h-6 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                My Orders
            </h2>
            
            <% if (orders && orders.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% orders.forEach(order => { %>
                        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-shadow relative overflow-hidden">
                            <!-- Status Badge -->
                            <div class="absolute top-0 right-0">
                                <% 
                                    const statusColors = {
                                        pending: 'bg-yellow-100 text-yellow-800',
                                        accepted: 'bg-blue-100 text-blue-800',
                                        completed: 'bg-green-100 text-green-800',
                                        cancelled: 'bg-red-100 text-red-800'
                                    };
                                    const colorClass = statusColors[order.status] || 'bg-slate-100';
                                %>
                                <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-bl-xl <%= colorClass %>">
                                    <%= order.status %>
                                </span>
                            </div>

                            <h4 class="font-bold text-slate-900 mb-1"><%= order.shopId ? order.shopId.shopName : 'Unknown Shop' %></h4>
                            <p class="text-xs text-slate-400 mb-4">Ordered on <%= new Date(order.createdAt).toLocaleDateString() %></p>
                            
                            <div class="space-y-2 mb-4">
                                <% order.items.forEach(item => { %>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-slate-600"><%= item.quantity %>x <%= item.name %></span>
                                        <span class="font-medium">₹<%= item.price * item.quantity %></span>
                                    </div>
                                <% }) %>
                            </div>

                            <div class="border-t border-slate-100 pt-4 flex justify-between items-center">
                                <div class="text-lg font-bold text-indigo-700">₹<%= order.totalAmount %></div>
                                
                                <% if (order.status !== 'completed' && order.status !== 'cancelled') { %>
                                    <div class="bg-indigo-50 border border-indigo-100 rounded-lg px-3 py-1.5 text-center">
                                        <p class="text-[10px] text-indigo-400 uppercase font-bold tracking-tighter">Your OTP</p>
                                        <p class="text-lg font-mono font-bold text-indigo-600 tracking-widest"><%= order.otp %></p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="bg-white rounded-2xl border-2 border-dashed border-slate-200 p-10 text-center">
                    <p class="text-slate-500">You haven't placed any orders yet.</p>
                    <a href="/customer/dashboard" class="mt-4 inline-block text-indigo-600 font-semibold hover:underline">Start shopping</a>
                </div>
            <% } %>
        </div>

        <h2 class="text-2xl font-bold mb-6 text-slate-800">Available Services</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <% if (shops && shops.length > 0) { %>
                <% shops.forEach(shop => { %>
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1 group">
                        <div class="h-40 bg-slate-200 relative overflow-hidden">
                            <% if (shop.image) { %>
                                <img src="<%= shop.image %>" alt="<%= shop.shopName %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center bg-indigo-100 text-indigo-400">
                                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                </div>
                            <% } %>
                            <div class="absolute top-3 right-3 bg-white/90 backdrop-blur text-indigo-700 text-xs font-bold px-3 py-1 rounded-full shadow-sm">
                                <%= shop.category.toUpperCase() %>
                            </div>
                        </div>
                        <div class="p-5">
                            <h3 class="text-xl font-bold mb-1 text-slate-900"><%= shop.shopName %></h3>
                            <p class="text-slate-500 text-sm mb-4 line-clamp-2"><%= shop.description || 'No description provided.' %></p>
                            
                            <div class="flex items-center justify-between mt-auto">
                                <span class="text-sm font-medium text-slate-500"><%= shop.services.length %> Services</span>
                                <a href="/customer/shop/<%= shop._id %>" class="inline-flex py-2 px-4 bg-indigo-50 text-indigo-700 font-semibold rounded-lg hover:bg-indigo-600 hover:text-white transition-colors">
                                    View Shop
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-16 text-center bg-white rounded-2xl border border-slate-200 border-dashed">
                    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <h3 class="text-xl font-medium text-slate-600 mb-1">No shops found</h3>
                    <p class="text-slate-500">We couldn't find any shops in your area yet. Check back later!</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>
