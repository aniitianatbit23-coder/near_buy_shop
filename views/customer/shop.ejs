<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= shop.shopName %> - NearBuy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800 pb-20">
    
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex items-center h-16">
                <a href="/customer/dashboard" class="text-indigo-600 hover:text-indigo-800 flex items-center mr-4">
                    <svg class="w-6 h-6 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back
                </a>
                <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600 truncate"><%= shop.shopName %></span>
            </div>
        </div>
    </nav>

    <!-- Header -->
    <div class="bg-indigo-700 text-white relative">
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-900 to-indigo-600 opacity-90"></div>
        <div class="max-w-7xl mx-auto px-4 py-12 relative z-10 flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1">
                <span class="inline-block bg-indigo-500/50 backdrop-blur rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider mb-3">
                    <%= shop.category %>
                </span>
                <h1 class="text-4xl md:text-5xl font-extrabold mb-2"><%= shop.shopName %></h1>
                <p class="text-indigo-100 text-lg mb-4 opacity-90 leading-relaxed"><%= shop.description || 'Welcome to our shop.' %></p>
                <div class="flex items-center gap-4 text-sm font-medium">
                    <span class="flex items-center bg-white/20 px-3 py-1.5 rounded-lg backdrop-blur shadow-sm">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        <%= shop.phone %>
                    </span>
                    <a href="https://wa.me/<%= shop.phone.replace(/[^0-9]/g, '') %>?text=Hi%20<%= encodeURIComponent(shop.shopName) %>,%20I%20found%20you%20on%20NearBuy." target="_blank" class="flex items-center bg-green-500 hover:bg-green-600 text-white px-4 py-1.5 rounded-lg shadow-md transition-colors">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        Chat
                    </a>
                </div>
            </div>
            <% if (shop.image) { %>
                <img src="<%= shop.image %>" class="w-32 h-32 md:w-48 md:h-48 rounded-2xl object-cover shadow-2xl border-4 border-indigo-500/30 hidden md:block">
            <% } %>
        </div>
    </div>

    <!-- Services Section -->
    <main class="max-w-7xl mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold text-slate-800 mb-6">Offered Services</h2>
        
        <form id="orderForm" action="/order/create" method="POST" class="grid lg:grid-cols-3 gap-8">
            <!-- Services List -->
            <div class="lg:col-span-2 space-y-4">
                <input type="hidden" name="shopId" value="<%= shop._id %>">
                <% if (shop.services && shop.services.length > 0) { %>
                    <% shop.services.forEach(service => { %>
                        <div class="flex items-center p-4 bg-white rounded-xl shadow-sm border border-slate-200 hover:border-indigo-400 transition-colors">
                            <div class="flex-1">
                                <h3 class="text-lg font-bold text-slate-900"><%= service.name %></h3>
                                <p class="text-sm text-slate-500 mb-2"><%= service.description %></p>
                                <span class="text-indigo-600 font-bold text-lg">₹<%= service.price %></span>
                            </div>
                            <div class="ml-4 flex items-center bg-slate-100 rounded-lg shadow-inner overflow-hidden">
                                <button type="button" class="px-4 py-2 text-slate-600 hover:bg-slate-200 transition-colors" onclick="updateQty('<%= service._id %>', <%= service.price %>, -1, '<%= service.name %>')">-</button>
                                <input type="number" id="qty-<%= service._id %>" name="items[<%= service._id %>][quantity]" value="0" min="0" class="w-12 text-center bg-transparent border-none font-semibold text-slate-800 focus:ring-0" readonly>
                                <input type="hidden" name="items[<%= service._id %>][price]" value="<%= service.price %>">
                                <input type="hidden" name="items[<%= service._id %>][name]" value="<%= service.name %>">
                                <button type="button" class="px-4 py-2 text-slate-600 hover:bg-slate-200 transition-colors" onclick="updateQty('<%= service._id %>', <%= service.price %>, 1, '<%= service.name %>')">+</button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="p-8 text-center bg-white rounded-xl border border-slate-200 border-dashed">
                        <p class="text-slate-500">This shop hasn't added any services yet.</p>
                    </div>
                <% } %>
            </div>

            <!-- Checkout Panel -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sticky top-24">
                    <h3 class="text-xl font-bold mb-4 flex items-center border-b pb-4">
                        <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        Your Order
                    </h3>
                    
                    <div id="cartItems" class="text-sm text-slate-600 mb-4 space-y-2 max-h-40 overflow-y-auto">
                        <p class="text-slate-400 italic" id="emptyCart">Add services to start order</p>
                    </div>
                    
                    <div class="flex justify-between items-center text-lg font-bold border-t border-slate-200 pt-4 mb-6">
                        <span>Total:</span>
                        <span class="text-indigo-600">₹<span id="totalDisplay">0</span></span>
                    </div>

                    <div class="space-y-3 mb-4">
                        <label class="block text-sm font-medium text-slate-700">Delivery Address / Instructions</label>
                        <textarea name="deliveryAddress" id="deliveryAddress" required 
                                  class="w-full border-slate-300 bg-slate-50 rounded-lg px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm h-20"
                                  placeholder="House No, Landmark, Specific Instructions..."></textarea>
                    </div>

                    <div class="space-y-3 mb-6">
                        <label class="block text-sm font-medium text-slate-700">Payment Method</label>
                        <select name="paymentMethod" class="w-full border-slate-300 bg-slate-50 rounded-lg px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm">
                            <option value="cod">Cash on Delivery / Pay at Shop</option>
                            <option value="online">Online Payment (Mock)</option>
                        </select>
                    </div>
                    
                    <button type="submit" id="checkoutBtn" disabled class="w-full bg-slate-300 text-white font-bold py-3 px-4 rounded-xl transition-all shadow-md">
                        Place Order
                    </button>
                </div>
            </div>
        </form>
    </main>

    <script>
        let total = 0;
        let cart = {};

        function updateQty(id, price, change, name) {
            const input = document.getElementById(`qty-${id}`);
            let qty = parseInt(input.value) + change;
            if (qty < 0) qty = 0;
            input.value = qty;

            if (qty > 0) {
                cart[id] = { name, qty, price };
            } else {
                delete cart[id];
            }
            
            updateCartDisplay();
        }

        function updateCartDisplay() {
            const cartDiv = document.getElementById('cartItems');
            const totalDisplay = document.getElementById('totalDisplay');
            const checkoutBtn = document.getElementById('checkoutBtn');
            const emptyCart = document.getElementById('emptyCart');

            if (Object.keys(cart).length === 0) {
                cartDiv.innerHTML = '<p class="text-slate-400 italic">Add services to start order</p>';
                totalDisplay.innerText = '0';
                checkoutBtn.disabled = true;
                checkoutBtn.className = "w-full bg-slate-300 text-white font-bold py-3 px-4 rounded-xl transition-all shadow-md cursor-not-allowed";
                return;
            }

            let html = '';
            total = 0;
            for (let id in cart) {
                const item = cart[id];
                const itemTotal = item.qty * item.price;
                total += itemTotal;
                html += `<div class="flex justify-between items-center">
                            <span>${item.qty}x ${item.name}</span>
                            <span class="font-medium">₹${itemTotal}</span>
                         </div>`;
            }

            cartDiv.innerHTML = html;
            totalDisplay.innerText = total;
            
            checkoutBtn.disabled = false;
            checkoutBtn.className = "w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 px-4 rounded-xl transition-all shadow-xl hover:-translate-y-0.5";
        }
    </script>
</body>
</html>
