<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopkeeper Dashboard - NearBuy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">
    
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <span class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-pink-500 to-orange-500">NearBuy <span class="text-sm font-medium text-slate-400 bg-slate-100 px-2 py-0.5 rounded ml-2">Partner</span></span>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-sm font-medium text-slate-600 hidden md:block"><%= shop.shopName %></span>
                    <a href="/logout" class="text-sm font-medium text-red-600 hover:text-red-500 bg-red-50 hover:bg-red-100 px-4 py-2 rounded-full transition-colors">Sign Out</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Header Section -->
    <div class="bg-gradient-to-r from-pink-600 to-orange-500 text-white py-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight mb-2">Dashboard overview</h1>
                <p class="text-white/80 text-lg">Manage your services and incoming orders.</p>
            </div>
            <div class="flex gap-4">
                <div class="bg-white/20 backdrop-blur rounded-xl p-4 text-center min-w-[120px]">
                    <p class="text-xs uppercase font-bold tracking-wider text-white/70 mb-1">Total Orders</p>
                    <p class="text-3xl font-bold"><%= orders ? orders.length : 0 %></p>
                </div>
                <div class="bg-white/20 backdrop-blur rounded-xl p-4 text-center min-w-[120px]">
                    <p class="text-xs uppercase font-bold tracking-wider text-white/70 mb-1">Services</p>
                    <p class="text-3xl font-bold"><%= shop.services.length %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid lg:grid-cols-3 gap-8">
        
        <!-- Left Column: Services Management -->
        <div class="lg:col-span-1 space-y-6">
            <h2 class="text-2xl font-bold text-slate-800 flex items-center">
                <svg class="w-6 h-6 mr-2 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                Your Services
            </h2>
            
            <!-- Add Service Form -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <h3 class="font-bold text-slate-800 mb-4 border-b pb-2">Add New Service</h3>
                <form action="/shopkeeper/service/add" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Service Name</label>
                        <input type="text" name="name" required class="w-full bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-500 focus:outline-none placeholder-slate-400" placeholder="e.g. Haircut, Plumbing Fix">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Description</label>
                        <textarea name="description" rows="2" class="w-full bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-500 focus:outline-none placeholder-slate-400" placeholder="Brief details about the service"></textarea>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Price (₹)</label>
                        <input type="number" name="price" required class="w-full bg-slate-50 border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-500 focus:outline-none" min="1">
                    </div>
                    <button type="submit" class="w-full bg-slate-800 hover:bg-slate-900 text-white font-bold py-2.5 px-4 rounded-lg transition-colors shadow-sm text-sm">
                        Add Service
                    </button>
                </form>
            </div>

            <!-- List of Services -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="max-h-96 overflow-y-auto">
                    <% if (shop.services && shop.services.length > 0) { %>
                        <ul class="divide-y divide-slate-100">
                        <% shop.services.forEach(service => { %>
                            <li class="p-4 hover:bg-slate-50 flex justify-between items-start group">
                                <div>
                                    <h4 class="font-bold text-slate-800"><%= service.name %></h4>
                                    <p class="text-xs text-slate-500"><%= service.description %></p>
                                    <p class="text-sm font-semibold text-pink-600 mt-1">₹<%= service.price %></p>
                                </div>
                                <form action="/shopkeeper/service/<%= service._id %>/delete" method="POST">
                                    <button type="submit" class="text-slate-300 hover:text-red-500 transition-colors p-1" title="Delete">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </li>
                        <% }) %>
                        </ul>
                    <% } else { %>
                        <div class="p-8 text-center text-slate-500">
                            No services added yet. Add some to get started!
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Right Column: Orders Management -->
        <div class="lg:col-span-2 space-y-6">
            <h2 class="text-2xl font-bold text-slate-800 flex items-center">
                <svg class="w-6 h-6 mr-2 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                Incoming Orders
            </h2>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <% if (orders && orders.length > 0) { %>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 text-slate-500 uppercase text-xs font-semibold tracking-wider">
                                    <th class="p-4 border-b border-slate-200">Order ID</th>
                                    <th class="p-4 border-b border-slate-200">Customer</th>
                                    <th class="p-4 border-b border-slate-200">Items & Total</th>
                                    <th class="p-4 border-b border-slate-200">Status</th>
                                    <th class="p-4 border-b border-slate-200 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% orders.forEach(order => { %>
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="p-4">
                                            <span class="font-mono text-xs text-slate-500 block">#<%= order._id.toString().substring(18) %></span>
                                            <span class="text-xs text-slate-400"><%= new Date(order.createdAt).toLocaleDateString() %></span>
                                        </td>
                                        <td class="p-4">
                                            <p class="font-semibold text-slate-800 text-sm"><%= order.userId.name %></p>
                                            <p class="text-xs text-slate-500"><%= order.userId.phone %></p>
                                        </td>
                                        <td class="p-4">
                                            <div class="text-xs text-slate-600 mb-1 max-w-[150px] truncate">
                                                <%= order.items.map(i => `${i.quantity}x ${i.name}`).join(', ') %>
                                            </div>
                                            <div class="font-bold text-orange-600">₹<%= order.totalAmount %> <span class="text-xs text-slate-400 font-normal uppercase bg-slate-100 px-1 rounded ml-1"><%= order.paymentMethod %></span></div>
                                        </td>
                                        <td class="p-4">
                                            <% 
                                                const statusColors = {
                                                    pending: 'bg-yellow-100 text-yellow-800 border-yellow-200',
                                                    accepted: 'bg-blue-100 text-blue-800 border-blue-200',
                                                    completed: 'bg-green-100 text-green-800 border-green-200',
                                                    cancelled: 'bg-red-100 text-red-800 border-red-200'
                                                };
                                                const colorClass = statusColors[order.status] || statusColors.pending;
                                            %>
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full border <%= colorClass %>">
                                                <%= order.status.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td class="p-4 text-right">
                                            <form action="/shopkeeper/order/<%= order._id %>/update" method="POST" class="inline-flex items-center gap-2">
                                                <select name="status" class="text-xs border-slate-300 bg-white rounded shadow-sm focus:ring-0">
                                                    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                                    <option value="accepted" <%= order.status === 'accepted' ? 'selected' : '' %>>Accept</option>
                                                    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Complete</option>
                                                    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancel</option>
                                                </select>
                                                <button type="submit" class="bg-slate-800 text-white text-xs px-2 py-1.5 rounded hover:bg-slate-700 transition">Update</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="p-16 text-center">
                        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                        </div>
                        <h3 class="text-xl font-medium text-slate-600 mb-1">No Orders Yet</h3>
                        <p class="text-slate-500">When customers place orders, they will appear here.</p>
                    </div>
                <% } %>
            </div>
        </div>

    </main>

    <!-- Notification Sound -->
    <audio id="notificationSound" preload="auto">
        <source src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" type="audio/mpeg">
    </audio>

    <!-- Socket.io & Notifications Script -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const userId = "<%= userId %>";
        const vapidPublicKey = "<%= vapidPublicKey %>";
        const audio = document.getElementById('notificationSound');

        // Register user for real-time socket events
        socket.emit('register', userId);

        socket.on('newOrder', (data) => {
            console.log('New Order Received via Socket:', data);
            
            // 1. Play Sound
            audio.play().catch(e => console.log('Audio play blocked/failed:', e));

            // 2. Browser Alert/Toast (if permission granted)
            if (Notification.permission === 'granted') {
                new Notification('New Order! 🛍️', {
                    body: `${data.customer} just placed an order for ₹${data.total}.`,
                    icon: '/images/logo.png'
                });
            } else {
                alert(`📦 NEW ORDER RECEIVED!\nAmount: ₹${data.total}\nFrom: ${data.customer}\n\nRefreshing page...`);
            }

            // 3. Refresh page to show new order in table
            setTimeout(() => {
                window.location.reload();
            }, 3000);
        });

        // --- Web Push Notification Registration ---

        async function registerPush() {
            if (!('serviceWorker' in navigator)) return;
            if (!('PushManager' in window)) return;

            try {
                // 1. Register Service Worker
                const register = await navigator.serviceWorker.register('/sw.js', {
                    scope: '/'
                });
                console.log('Service Worker Registered');

                // 2. Request Notification Permission
                const permission = await Notification.requestPermission();
                if (permission !== 'granted') return;

                // 3. Register for Push
                const subscription = await register.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: urlBase64ToUint8Array(vapidPublicKey)
                });
                console.log('Push Registered');

                // 4. Send subscription to server
                await fetch('/api/notifications/subscribe', {
                    method: 'POST',
                    body: JSON.stringify({
                        subscription: subscription,
                        userId: userId,
                        role: 'shopkeeper'
                    }),
                    headers: {
                        'content-type': 'application/json'
                    }
                });
            } catch (error) {
                console.error('Push Registration Error:', error);
            }
        }

        // Helper to convert VAPID key
        function urlBase64ToUint8Array(base64String) {
            const padding = '='.repeat((4 - base64String.length % 4) % 4);
            const base64 = (base64String + padding)
                .replace(/\-/g, '+')
                .replace(/_/g, '/');

            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);

            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }

        // Auto-run on load
        window.addEventListener('load', () => {
            registerPush();
        });
    </script>
</body>
</html>
